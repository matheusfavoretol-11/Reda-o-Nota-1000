<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 310 551" width="310" height="551">
  <defs>
    <linearGradient id="videoBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#050508"/>
      <stop offset="60%" stop-color="#111115"/>
      <stop offset="100%" stop-color="#1c1c24"/>
    </linearGradient>
    <linearGradient id="neonGreenGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#00FF88"/>
      <stop offset="100%" stop-color="#00FFD1"/>
    </linearGradient>
    <linearGradient id="accentOrangeGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#FF6B35"/>
      <stop offset="100%" stop-color="#FF3366"/>
    </linearGradient>
    <filter id="videoGlow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="6" stdDeviation="15" flood-color="#00FF88" flood-opacity="0.25"/>
    </filter>
    <filter id="playBtnGlow" x="-30%" y="-30%" width="160%" height="160%">
      <feDropShadow dx="0" dy="10" stdDeviation="20" flood-color="#FF3366" flood-opacity="0.4"/>
    </filter>
  </defs>

  <!-- Background -->
  <rect width="310" height="551" fill="url(#videoBg)"/>

  <!-- Aesthetic Grid details -->
  <g opacity="0.08">
    <path d="M 0,55 L 310,55 M 0,110 L 310,110 M 0,165 L 310,165 M 0,220 L 310,220 M 0,275 L 310,275 M 0,330 L 310,330 M 0,385 L 310,385 M 0,440 L 310,440 M 0,495 L 310,495" stroke="#ffffff" stroke-width="0.5"/>
    <path d="M 31,0 L 31,551 M 62,0 L 62,551 M 93,0 L 93,551 M 124,0 L 124,551 M 155,0 L 155,551 M 186,0 L 186,551 M 217,0 L 217,551 M 248,0 L 248,551 M 279,0 L 279,551" stroke="#ffffff" stroke-width="0.5"/>
  </g>

  <!-- Tech Diagonal lines -->
  <path d="M -50,150 L 360,560" stroke="url(#neonGreenGrad)" stroke-width="1.5" opacity="0.1"/>
  <path d="M -50,50 L 360,460" stroke="url(#accentOrangeGrad)" stroke-width="1.5" opacity="0.07"/>

  <!-- Top bar logo design simulation inside video -->
  <g transform="translate(20, 45)" opacity="0.85">
    <rect width="6" height="15" rx="2" fill="url(#neonGreenGrad)"/>
    <text x="14" y="12" fill="#ffffff" font-family="'Inter', sans-serif" font-size="11" font-weight="900" letter-spacing="1">MÉTODO RED 1000</text>
  </g>

  <!-- Big glowing Center Play Button -->
  <g transform="translate(155, 275.5)" filter="url(#playBtnGlow)">
    <circle r="44" fill="url(#accentOrangeGrad)"/>
    <circle r="44" fill="none" stroke="#ffffff" stroke-width="1.5" opacity="0.3"/>
    <!-- Play Triangle -->
    <path d="M -8,-14 L 16,0 L -8,14 Z" fill="#ffffff" transform="translate(2, 0)"/>
  </g>

  <!-- Bottom course badge information -->
  <g transform="translate(25, 450)" filter="url(#videoGlow)">
    <rect x="0" y="0" width="260" height="60" rx="16" fill="#000000" fill-opacity="0.6" stroke="url(#neonGreenGrad)" stroke-width="1.5"/>
    
    <text x="130" y="24" text-anchor="middle" fill="url(#neonGreenGrad)" font-family="'Inter', sans-serif" font-size="12" font-weight="900" letter-spacing="1.5">SISTEMA DE BLOCOS LÓGICOS</text>
    <text x="130" y="44" text-anchor="middle" fill="#ffffff" font-family="'Inter', sans-serif" font-size="11" font-weight="700" opacity="0.8">COMO SAIR DO ZERO E GARANTIR 900+</text>
  </g>

  <!-- Live/Online viewer icon simulation -->
  <g transform="translate(25, 100)">
    <rect width="70" height="24" rx="12" fill="#FF3366" fill-opacity="0.1" stroke="#FF3366" stroke-width="1"/>
    <circle cx="16" cy="12" r="4" fill="#FF3366"/>
    <text x="26" y="16" fill="#FF3366" font-family="'Inter', sans-serif" font-size="10" font-weight="800" letter-spacing="0.5">AO VIVO</text>
  </g>

  <g transform="translate(102, 100)">
    <rect width="65" height="24" rx="12" fill="#ffffff" fill-opacity="0.04" stroke="#ffffff" stroke-opacity="0.1" stroke-width="1"/>
    <text x="32.5" y="15" text-anchor="middle" fill="#ffffff" font-family="'Inter', sans-serif" font-size="9" font-weight="700" opacity="0.8">DEMO</text>
  </g>
</svg>
